doctype html
html

  head
    title Edit Blog

    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")

    link(
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    )

    style.
      html, body {
        height: 100%;
        margin: 0;
      }
      
      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background-color: #f8f9fa;
      }
      
      .main-content {
        flex: 1;
      }

      .edit-card {
        border: none;
        border-radius: 22px;
        overflow: hidden;
        transition: 0.3s ease;
      }

      .edit-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 45px rgba(0,0,0,0.18);
      }

      .form-control {
        border-radius: 12px;
        padding: 12px;
      }

      textarea.form-control {
        resize: none;
      }

      .btn {
        border-radius: 12px;
        padding: 12px;
        font-weight: 600;
        transition: 0.3s;
      }

      .btn:hover {
        transform: scale(1.02);
      }

  body.bg-light

    include partials/navbar
    .main-content

     .container.mt-5

      .row.justify-content-center

        .col-md-8

          .card.edit-card.shadow-lg

            .card-body.p-5

              h2.text-center.mb-4.fw-bold
                | Edit Blog

              form(action='/blogs/edit/' + blog._id method='POST')

                .mb-4

                  label.form-label.fw-semibold
                    | Blog Title

                  input.form-control(
                    type='text'
                    name='title'
                    value=blog.title
                    required
                  )

                .mb-4

                  label.form-label.fw-semibold
                    | Blog Content

                  textarea.form-control(
                    name='content'
                    rows='8'
                    required
                  )= blog.content

                .d-grid.mb-3

                  button.btn.btn-warning(type='submit')
                    | Update Blog

              hr

              .d-grid

                a.btn.btn-secondary(href='/blogs')
                  | Back to Blogs
                  
    include partials/footer