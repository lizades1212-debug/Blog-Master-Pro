doctype html
html

  head
    title Dashboard

    link(
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    )

    style.
      body {
        background: #f8f9fa;
      }

      .dashboard-card {
        border: none;
        border-radius: 22px;
        overflow: hidden;
        transition: 0.3s ease;
      }

      .dashboard-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 45px rgba(0,0,0,0.18);
      }

      .welcome-title {
        font-size: 3rem;
        font-weight: 700;
      }

      .lead {
        font-size: 1.2rem;
      }

      .btn {
        border-radius: 12px;
        padding: 14px;
        font-weight: 600;
        transition: 0.3s;
      }

      .btn:hover {
        transform: scale(1.03);
      }

  body.bg-light

    include partials/navbar

    .container.mt-5

      .row.justify-content-center

        .col-md-8

          .card.dashboard-card.shadow-lg

            .card-body.text-center.p-5

              h1.welcome-title
                | Welcome #{user.firstName}

              p.lead.text-muted.mb-4
                | Blog Master Pro Dashboard

              .d-grid.gap-3.col-6.mx-auto.mt-4

                a.btn.btn-primary.btn-lg(href="/blogs")
                  | View Blogs

                a.btn.btn-success.btn-lg(href="/blogs/create")
                  | Create Blog

                a.btn.btn-danger.btn-lg(href="/logout")
                  | Logout
                  
    include partials/footer