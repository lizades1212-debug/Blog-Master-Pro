doctype html
html

  head
    title Register

    link(
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    )

    style.
      body {
        background: linear-gradient(to right, #f8f9fa, #e3f2fd);
      }

      .register-card {
        border: none;
        border-radius: 24px;
        overflow: hidden;
        transition: 0.3s ease;
      }

      .register-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 45px rgba(0,0,0,0.18);
      }

      .form-control {
        border-radius: 12px;
        padding: 12px;
      }

      .btn {
        border-radius: 12px;
        padding: 12px;
        font-weight: 600;
        transition: 0.3s;
      }

      .btn:hover {
        transform: scale(1.02);
      }

      .alert {
        border-radius: 12px;
      }

  body

    .container.mt-5

      .row.justify-content-center

        .col-md-6.col-lg-5

          .card.register-card.shadow-lg

            .card-body.p-5

              h2.text-center.mb-4.fw-bold
                | Register

              if error_msg.length > 0

                .alert.alert-danger.shadow-sm
                  = error_msg[0]

              if success_msg.length > 0

                .alert.alert-success.shadow-sm
                  = success_msg[0]

              form(action="/register" method="POST")

                .mb-4

                  label.form-label.fw-semibold
                    | First Name

                  input.form-control(
                    type="text"
                    name="firstName"
                    placeholder="Enter First Name"
                    required
                  )

                .mb-4

                  label.form-label.fw-semibold
                    | Last Name

                  input.form-control(
                    type="text"
                    name="lastName"
                    placeholder="Enter Last Name"
                    required
                  )

                .mb-4

                  label.form-label.fw-semibold
                    | Email

                  input.form-control(
                    type="email"
                    name="email"
                    placeholder="Enter Email"
                    required
                  )

                .mb-4

                  label.form-label.fw-semibold
                    | Password

                  input.form-control(
                    type="password"
                    name="password"
                    placeholder="Enter Password"
                    required
                  )

                button.btn.btn-primary.w-100(type="submit")
                  | Register

              hr

              p.text-center.text-muted
                | Already have an account?

              .d-grid

                a.btn.btn-outline-secondary(href="/login")
                  | Login
                  
    include partials/footer