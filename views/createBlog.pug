doctype html
html

  head
    title Create Blog

    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")

    link(
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    )

    style.

      html, body {
        height: 100%;
        margin: 0;
      }

      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background-color: #f8f9fa;

      }

      .main-content {
        flex: 1;
      }

      .blog-card {
        border: none;
        border-radius: 22px;
        overflow: hidden;
        transition: 0.3s ease;
      }

      .blog-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 45px rgba(0,0,0,0.18);
      }

      .form-control {
        border-radius: 12px;
        padding: 12px;
      }

      textarea.form-control {
        resize: none;
      }

      .btn {
        border-radius: 12px;
        padding: 12px;
        font-weight: 600;
        transition: 0.3s;
      }

      .btn:hover {
        transform: scale(1.02);
      }

  body.bg-light

    include partials/navbar
    .main-content

      .container.mt-5

       .row.justify-content-center

        .col-md-8

          .card.blog-card.shadow-lg

            .card-body.p-5

              h2.text-center.mb-4.fw-bold
                | Create Blog

              form(action="/blogs/create" method="POST")

                .mb-4

                  label.form-label.fw-semibold
                    | Blog Title

                  input.form-control(
                    type="text"
                    name="title"
                    placeholder="Enter Blog Title"
                    required
                  )

                .mb-4

                  label.form-label.fw-semibold
                    | Blog Content

                  textarea.form-control(
                    name="content"
                    rows="8"
                    placeholder="Write your blog here..."
                    required
                  )

                button.btn.btn-success.w-100(type="submit")
                  | Publish Blog

    include partials/footer