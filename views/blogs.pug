doctype html
html

head
  title Blogs

  link(
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  )

  style.
    body {
      background-color: #f8f9fa;
    }

    .card {
      border: none;
      border-radius: 18px;
      transition: all 0.3s ease;
      overflow: hidden;
    }

    .card:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 45px rgba(0,0,0,0.25) !important;
    }

    .card-body {
      padding: 30px;
    }

    .card-title {
      font-weight: 700;
      font-size: 2rem;
      margin-bottom: 15px;
    }

    .card-text {
      font-size: 17px;
      line-height: 1.7;
    }

    .badge {
      font-size: 14px;
      padding: 8px 14px;
      border-radius: 8px;
    }

    .btn {
      border-radius: 10px;
      padding: 10px 18px;
      font-weight: 500;
    }

    .alert {
      border-radius: 12px;
    }

    hr {
      margin-top: 25px;
      margin-bottom: 25px;
    }
  body

    include partials/navbar

    .container.mt-4.mb-5

      h1.text-center.mb-5.fw-bold All Blogs

      if success_msg.length > 0
        .alert.alert-success.shadow-sm
          = success_msg[0]

      if error_msg.length > 0
        .alert.alert-danger.shadow-sm
          = error_msg[0]

      each blog in blogs

        .card.mb-4.shadow-sm

          .card-body

            h2.card-title= blog.title

            p.card-text= blog.content

            p.text-muted.mt-3
              | Written by #{blog.author ? blog.author.firstName : "Deleted User"}

            p.text-muted
              = new Date(blog.createdAt).toDateString()

            if blog.approveStatus === "approved"
              span.badge.bg-success Approved

            else if blog.approveStatus === "pending"
              span.badge.bg-warning.text-dark Pending

            else if blog.approveStatus === "reviewed"
              span.badge.bg-secondary Reviewed

            else if blog.approveStatus === "rejected"
              span.badge.bg-dark Rejected

            else if blog.approveStatus === "delete-pending"
              span.badge.bg-danger Delete Request Pending

            br
            br

            if user && (user.role === "admin" || (blog.author && user.id == blog.author._id))

              a.btn.btn-warning.me-2(
                href='/blogs/edit/' + blog._id
              )
                | Edit Blog

              if blog.approveStatus !== "delete-pending"

                form.d-inline(
                  action='/blogs/delete/' + blog._id
                  method='POST'
                )

                  button.btn.btn-danger(
                    type='submit'
                    onclick="return confirm('Are you sure you want to delete this blog?')"
                  )
                    | Delete Blog

            if user && user.role === "admin"

              hr

              form.d-inline(
                action='/blogs/review/' + blog._id
                method='POST'
              )

                button.btn.btn-secondary.me-2(type='submit')
                  | Mark as Reviewed

              form.d-inline(
                action='/blogs/approve/' + blog._id
                method='POST'
              )

                button.btn.btn-success.me-2(type='submit')
                  | Approve Blog

              form.d-inline(
                action='/blogs/reject/' + blog._id
                method='POST'
              )

                button.btn.btn-dark.me-2(type='submit')
                  | Reject Blog

              if blog.approveStatus === "delete-pending"

                form.d-inline(
                  action='/blogs/delete-approve/' + blog._id
                  method='POST'
                )

                  button.btn.btn-danger(type='submit')
                    | Approve Delete